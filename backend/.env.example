# ================================================================
# Resume Review Workflow System — Environment Variables Template
# ================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ================================================================

# ─── Database ───────────────────────────────────────────────────
# SQL Server connection string
# Replace HOSTNAME with your machine name or 'localhost'
# Replace INSTANCENAME with your SQL Server instance (e.g., SQLEXPRESS)
# Replace YourPassword with your SA password
DATABASE_URL=mssql+pyodbc://sa:YourPassword@HOSTNAME\INSTANCENAME/ResumeReviewDB?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# ─── JWT Authentication ─────────────────────────────────────────
# Use a long random string — minimum 32 characters
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-long-random-secret-key

# JWT algorithm — keep as HS256 unless you know what you're changing
ALGORITHM=HS256

# Token validity in minutes (60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Email (Gmail SMTP) ─────────────────────────────────────────
# Gmail SMTP host — do not change for Gmail
EMAIL_HOST=smtp.gmail.com

# Gmail TLS port — do not change for Gmail
EMAIL_PORT=587

# Your Gmail address used for sending emails
EMAIL_USER=youremail@gmail.com

# Gmail App Password — NOT your Gmail login password
# Generate at: myaccount.google.com/security → App Passwords
# Paste the 16-char code WITHOUT spaces
EMAIL_PASSWORD=your16charapppassword

# ─── Application ────────────────────────────────────────────────
# Base URL of your frontend — used in magic review links sent to TLs
# Change to your production domain when deploying
FRONTEND_URL=http://localhost:5173
